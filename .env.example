# ─── Server ───
PORT=5000
ASPNETCORE_ENVIRONMENT=Development        # Development | Production
AUTO_SEED=true                             # Auto-run seed script on first boot
AUTO_MIGRATE=true                          # Auto-apply EF Core migrations on container startup. Set false for CI-triggered manual migrations.

# ─── Database ───
DATABASE_URL=Host=localhost;Port=5432;Database=contract_engine;Username=contract_engine;Password=localdev

# ─── Tenant Management ───
SELF_REGISTRATION_ENABLED=true             # true = public POST /api/tenants/register
DEFAULT_TENANT_NAME=Default                # Name for the auto-seeded first tenant

# ─── Document Storage ───
DOCUMENT_STORAGE_PATH=data/documents       # Local path for uploaded contract files

# ─── Extraction Settings ───
EXTRACTION_BATCH_SIZE=5                    # Max extraction jobs per scheduler tick
EXTRACTION_RETRY_MAX=3                     # Max retries for failed extraction jobs

# ─── Alert Settings ───
ALERT_WINDOWS_DAYS=90,30,14,7,1           # Days before deadline to generate alerts
DEFAULT_GRACE_PERIOD_DAYS=3                # Business days of grace after deadline
OVERDUE_ESCALATION_DAYS=14                 # Business days overdue before escalation

# ─── RAG Platform Integration ───
RAG_PLATFORM_URL=xxxxx
RAG_PLATFORM_API_KEY=xxxxx
RAG_PLATFORM_ENABLED=true                  # false = extraction/diff/conflict disabled

# ─── Notification Hub Integration ───
NOTIFICATION_HUB_URL=xxxxx
NOTIFICATION_HUB_API_KEY=xxxxx
NOTIFICATION_HUB_ENABLED=false             # false = alerts in DB only, no push

# ─── Webhook Engine Integration ───
WEBHOOK_SIGNING_SECRET=xxxxx               # HMAC-SHA256 secret for verifying webhooks
WEBHOOK_ENGINE_ENABLED=false               # false = webhook receiver returns 404

# ─── Workflow Engine Integration ───
WORKFLOW_ENGINE_URL=xxxxx
WORKFLOW_ENGINE_API_KEY=xxxxx
WORKFLOW_ENGINE_ENABLED=false              # false = no approval workflows triggered

# ─── Financial Compliance Ledger (NATS) ───
NATS_URL=nats://localhost:4222
COMPLIANCE_LEDGER_ENABLED=false            # false = no NATS events published

# ─── Invoice Reconciliation Engine ───
INVOICE_RECON_URL=xxxxx
INVOICE_RECON_API_KEY=xxxxx
INVOICE_RECON_ENABLED=false                # false = no auto-PO creation

# ─── Observability ───
SENTRY_DSN=xxxxx                           # Sentry DSN for error tracking (empty = disabled)
LOG_LEVEL=Information                      # Serilog: Verbose | Debug | Information | Warning | Error
